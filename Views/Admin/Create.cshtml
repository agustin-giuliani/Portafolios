@using TuProyecto.Models
@model Proyecto

@{
    ViewData["Title"] = "Nuevo Proyecto";
}

<div class="container py-5">
    <h2 class="mmb-4 text-center fw-bold" data-aos="fade-down">
        <i class="bi bi-plus-circle me-2"></i> Crear Nuevo Proyecto
    </h2>

    <div class="row justify-content-center">
        <div class="col-lg-8" data-aos="fade-up">
            <form asp-action="Create" method="post" enctype="multipart/form-data" class="shadow-sm p-4 rounded bg-light">

                <div class="mb-3">
                    <label asp-for="Titulo" class="form-label">Título</label>
                    <input asp-for="Titulo" class="form-control" placeholder="Ej: App de inventario WinForms" />
                    <span asp-validation-for="Titulo" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Descripcion" class="form-label">Descripción</label>
                    <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Describe brevemente tu proyecto..."></textarea>
                    <span asp-validation-for="Descripcion" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Tecnologias" class="form-label">Tecnologías</label>
                    <input asp-for="Tecnologias" class="form-control" placeholder="Ej: C#, SQL Server, WinForms" />
                    <span asp-validation-for="Tecnologias" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Url" class="form-label">URL del Proyecto (opcional)</label>
                    <input asp-for="Url" class="form-control" type="text" placeholder="https://github.com/mi-proyecto" />
                    <span asp-validation-for="Url" class="text-danger"></span>
                </div>

                <div class="mb-3" required="false">
                    <label asp-for="ArchivoProyecto" class="form-label">Archivo del Proyecto</label>
                    <input asp-for="ArchivoProyecto" type="file" class="form-control" />
                    <span asp-validation-for="ArchivoProyecto" class="text-danger"></span>
                </div>

                <div class="form-check form-switch mb-4">
                    <input asp-for="Publicado" class="form-check-input" type="checkbox" />
                    <label asp-for="Publicado" class="form-check-label">¿Publicado?</label>
                </div>

                <div class="text-end">
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-check-circle me-1"></i> Guardar
                    </button>
                    <a asp-action="Index" class="btn btn-secondary ms-2">
                        <i class="bi bi-x-circle me-1"></i> Cancelar
                    </a>
                </div>

            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}


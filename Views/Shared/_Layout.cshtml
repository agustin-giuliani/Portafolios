<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Portfolio</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Portafolio.styles.css" asp-append-version="true" />

    <!-- Animaciones -->
    <link href="https://unpkg.com/aos@2.3.1/dist/aos.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <style>
        html, body {
            height: 100%;
            margin: 0;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        main {
            flex: 1;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm sticky-top">
            <div class="container">
                <a class="navbar-brand" href="/">
                    <i class="bi bi-terminal-fill me-2"></i>Portfolio Agustin Giuliani
                </a>
                <span class="navbar-text text-light ms-3 small d-none d-lg-inline">
                    Desarrollador | Data Analyst
                </span>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                        aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">

                        @if (Context.Session.GetString("UserRole") == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-speedometer2 me-1"></i>Dashboard
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Index">
                                    <i class="bi bi-folder me-1"></i>Proyectos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Admin" asp-action="Visitas">
                                    <i class="bi bi-graph-up me-1"></i>Visitas
                                </a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Index">
                                    <i class="bi bi-house-door me-1"></i>Inicio
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="About">
                                    <i class="bi bi-person-circle me-1"></i>Sobre mí
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Projects">
                                    <i class="bi bi-folder2-open me-1"></i>Proyectos
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-controller="Home" asp-action="Contact">
                                    <i class="bi bi-envelope me-1"></i>Contacto
                                </a>
                            </li>
                        }

                    </ul>
                    @* 👇 BOTÓN LOGOUT *@
                    @if (Context.Session.GetString("UserRole") == "Admin")
                    {
                        <a class="btn btn-outline-danger ms-3"
                           asp-controller="Auth"
                           asp-action="Logout">
                            <i class="bi bi-box-arrow-right me-1"></i>Logout
                        </a>
                    }
                </div>
            </div>
        </nav>
    </header>

    <!-- Contenido principal -->
    <main role="main">
        <div class="container py-4">
            @RenderBody()
        </div>
    </main>

    <footer class="bg-dark text-white text-center py-3 mt-auto">
        <div class="container">
            <p class="mb-1 mb-md-0">
                &copy; 2025 Agustín Giuliani — Técnico Superior en Desarrollo de Software
            </p>
            <small class="text-secondary">Sitio desarrollado con ASP.NET Core MVC</small>
            <small class="d-block mt-2">
                <a href="/Home/Contact" class="text-decoration-none text-light">
                    Ir a contacto <i class="bi bi-arrow-right-circle ms-1"></i>
                </a>
            </small>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://unpkg.com/aos@2.3.1/dist/aos.js"></script>
    <script>
        AOS.init({
            duration: 1000,
            once: true
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

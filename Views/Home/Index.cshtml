@{
    ViewData["Title"] = "Inicio";
}
@using TuProyecto.Models
@model Proyecto

<div class="container py-5">

    <!-- HERO -->
    <div class="text-center mb-5" data-aos="fade-down">
        <h1 class="display-4 fw-bold">
            Agustín Giuliani
        </h1>

        <p class="lead text-muted">
            Desarrollador Backend | Data Analyst
        </p>

        <div class="mt-4">
            <a href="/Home/Projects" class="btn btn-primary me-2">
                <i class="bi bi-folder2-open me-1"></i> Ver proyectos
            </a>

            <a href="/Home/Contact" class="btn btn-outline-dark">
                <i class="bi bi-envelope me-1"></i> Contacto
            </a>
        </div>
    </div>

    <!-- SOBRE MI + FOTO -->
    <div class="row align-items-center mb-5">

        <div class="col-lg-5 text-center" data-aos="fade-right">
            <img src="~/img/agus.jpeg"
                 class="img-fluid rounded shadow"
                 style="max-width: 280px;" />
        </div>

        <div class="col-lg-7" data-aos="fade-left">
            <h3 class="mb-3">
                <i class="bi bi-person-workspace me-2"></i>Sobre mí
            </h3>

            <p>
                Trabajo en soporte técnico con sistemas ERP, realizando consultas SQL, validación de datos
                y análisis de información en entornos reales.
            </p>

            <p class="mb-0">
                Actualmente desarrollo proyectos en <strong>C#, .NET y SQL</strong> y me estoy formando en
                <strong>Data Analytics con Python</strong>.
            </p>
        </div>

    </div>

    <!-- STACK -->
    <div class="card shadow-sm border-0 mb-5" data-aos="fade-up">
        <div class="card-body text-center">

            <h4 class="mb-4">
                <i class="bi bi-cpu-fill me-2"></i>Stack tecnológico
            </h4>

            <div class="d-flex flex-wrap justify-content-center gap-2">

                <span class="badge bg-primary">C#</span>
                <span class="badge bg-primary">.NET</span>
                <span class="badge bg-primary">SQL</span>

                <span class="badge bg-success">SQL Server</span>
                <span class="badge bg-success">MySQL</span>

                <span class="badge bg-warning text-dark">Python</span>
                <span class="badge bg-warning text-dark">Power Bi</span>

                <span class="badge bg-dark">Git</span>
                <span class="badge bg-dark">ASP.NET MVC</span>

            </div>

        </div>
    </div>
    <div class="text-center text-muted mt-5">
    <p>Podés ver mis proyectos desde el botón superior o el menú.</p>
        @if (Model != null)
        {
            <div class="mt-5" data-aos="fade-up">

                <h3 class="text-center mb-4">
                    <i class="bi bi-stars me-2"></i>Proyecto destacado
                </h3>

                <div class="row justify-content-center">
                    <div class="col-lg-6">

                        <div class="card shadow-sm">
                            <div class="card-body text-center">

                                <h5 class="card-title">@Model.Titulo</h5>

                                <p class="text-muted">
                                    @Model.Descripcion
                                </p>

                                <div class="mb-3">
                                    @foreach (var tech in Model.Tecnologias.Split(',', StringSplitOptions.RemoveEmptyEntries))
                                    {
                                        <span class="badge bg-dark me-1">@tech.Trim()</span>
                                    }
                                </div>

                                @if (!string.IsNullOrEmpty(Model.Url))
                                {
                                    <a href="@Model.Url" target="_blank" class="btn btn-outline-primary">
                                        <i class="bi bi-box-arrow-up-right me-1"></i> Ver proyecto
                                    </a>
                                }

                            </div>
                        </div>

                    </div>
                </div>

            </div>
        }
</div>

</div>

